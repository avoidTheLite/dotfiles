{
  "version": 3,
  "description": "Style and convention guides. Only includes files that exist in the repo. Top-level roles: monorepo, server, client; languages under each.",
  "default_full_stack_typescript": [
    "ts.monorepo",
    "ts.server",
    "ts.client"
  ],
  "default_full_stack_python": ["py.monorepo", "py.server"],
  "guides": [
    {
      "id": "ts.monorepo",
      "path": "guides/monorepo/typescript/STYLE_GUIDE.md",
      "language": "typescript",
      "role": "monorepo",
      "pillar": "application",
      "domains": ["monorepo", "tooling"],
      "tooling": ["node", "typescript", "eslint", "prettier", "vitest", "pnpm", "turborepo", "knex"]
    },
    {
      "id": "py.monorepo",
      "path": "guides/monorepo/python/STYLE_GUIDE.md",
      "language": "python",
      "role": "monorepo",
      "pillar": "application",
      "domains": ["monorepo", "tooling", "openapi"],
      "prerequisites": ["ts.monorepo"],
      "tooling": ["python", "uv", "ruff", "pyright", "pydantic", "pytest", "turborepo"]
    },
    {
      "id": "ts.server",
      "path": "guides/server/typescript/STYLE_GUIDE.md",
      "language": "typescript",
      "role": "server",
      "pillar": "application",
      "domains": ["api", "express", "logging", "database"],
      "prerequisites": ["ts.monorepo"],
      "tooling": ["express", "pino", "zod", "knex"]
    },
    {
      "id": "ts.client",
      "path": "guides/client/typescript/STYLE_GUIDE.md",
      "language": "typescript",
      "role": "client",
      "pillar": "application",
      "domains": ["react", "tailwind", "tanstack-query", "zustand"],
      "prerequisites": ["ts.monorepo"],
      "tooling": ["react", "vitest", "msw", "testing-library", "tailwind"]
    },
    {
      "id": "py.server",
      "path": "guides/server/python/STYLE_GUIDE.md",
      "language": "python",
      "role": "server",
      "pillar": "application",
      "domains": ["api", "logging", "database"],
      "prerequisites": ["py.monorepo"],
      "tooling": ["fastapi", "pydantic", "uv", "pytest"],
      "note": "Standalone FastAPI/server guide; mutually exclusive with ts.server for the same HTTP API."
    },
    {
      "id": "py.client",
      "path": "guides/client/python/STYLE_GUIDE.md",
      "language": "python",
      "role": "client",
      "pillar": "application",
      "domains": ["ui"],
      "prerequisites": ["py.monorepo", "ts.monorepo"],
      "tooling": [],
      "note": "Section slots mirror TypeScript client; choose UI stack before expanding."
    },
    {
      "id": "py.ai",
      "path": "guides/ai/python/STYLE_GUIDE.md",
      "language": "python",
      "role": "ai",
      "pillar": "application",
      "domains": ["agents", "llm"],
      "prerequisites": ["py.monorepo"],
      "tooling": [],
      "note": "Stub; expand when AI packages land."
    },
    {
      "id": "py.cli",
      "path": "guides/cli/python/STYLE_GUIDE.md",
      "language": "python",
      "role": "cli",
      "pillar": "application",
      "domains": ["cli"],
      "prerequisites": ["py.monorepo"],
      "tooling": ["typer"],
      "note": "Stub; expand when CLI packages land."
    },
    {
      "id": "py.data",
      "path": "guides/data/python/STYLE_GUIDE.md",
      "language": "python",
      "role": "data",
      "pillar": "application",
      "domains": ["etl", "analytics"],
      "prerequisites": ["py.monorepo"],
      "tooling": ["polars"],
      "note": "Stub; expand when data pipelines land."
    }
  ]
}

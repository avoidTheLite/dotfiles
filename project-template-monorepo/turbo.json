{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.config.ts", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.config.ts", "eslint.config.js"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.config.ts"],
      "outputs": ["coverage/**"]
    }
  }
}
